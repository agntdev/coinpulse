[
  {
    "name": "quiet: menu shows current state for onboarded user",
    "steps": [
      { "send": { "text": "/start" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "onboard:currency:usd" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "onboard:tz:0" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "quiet:menu" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] }
    ]
  },
  {
    "name": "quiet: set and disable quiet hours",
    "steps": [
      { "send": { "text": "/start" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "onboard:currency:usd" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "onboard:tz:0" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "quiet:menu" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "quiet:set:22:00:08:00" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "quiet:menu" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] },
      { "send": { "callback": "quiet:disable" }, "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }] }
    ]
  }
]